SELECT h.hacker_id, h.name, s.score,
ROW_NUMBER() OVER (PARTITION BY h.hacker_id, s.challenge_id ORDER BY s.score DESC) AS rn
FROM Hackers h   
JOIN Submissions s
ON h.hacker_id = s.hacker_id
WHERE s.score > 0
) AS X
WHERE X.rn = 1
GROUP BY X.hacker_id, X.name
ORDER BY SUM(X.score) DESC, X.hacker_id

