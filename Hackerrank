SELECT PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY Score)
       OVER () AS MedianValue
FROM YourTable;


select
	h.hacker_id,
	h.name
from
	hackers h
	inner join
	(
		select
			s.hacker_id,
			count(*) as cnt
		from
			challenges c
			inner join difficulty d
				on c.difficulty_level = d.difficulty_level
			inner join submissions s
				on c.challenge_id = s.challenge_id
		where
			s.score = d.score
		group by s.hacker_id
		having count(*) > 1
	) as ch
		on h.hacker_id = ch.hacker_id
order by
	ch.cnt desc,
	h.hacker_id

