--this means that I'm cross joining selecting from 2 tables


SELECT
CASE WHEN Grade < 8 
THEN NULL 
ELSE Name END,
Grade, 
Marks
FROM
Grades
CROSS JOIN Students
WHERE Marks BETWEEN Min_Mark AND Max_Mark
ORDER BY Grade desc, Name;
