CREATE PROCEDURE dbo.procTest
@Description nvarchar(200)
AS
BEGIN
DECLARE @IDNumber INT;
INSERT INTO dbo.tblTest(Id, Description)
VALUES (-555, @Description);
SELECT @IDNumber = ID
FROM dbo.tblTest
WHERE Description = @Description;
RETURN @IDNumber;
END
GO
